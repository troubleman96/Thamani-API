# App
APP_NAME=Thamani API
APP_ENV=development
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8050
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-prod-min-64-chars
ALLOWED_ORIGINS=http://localhost:5173,https://thamani.co.tz

# Database
DATABASE_URL=postgresql+asyncpg://camel:password@localhost:5432/thamani_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8050/api/v1/auth/google/callback

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8050/api/v1/auth/github/callback

# Frontend URL (for OAuth redirect after login)
FRONTEND_URL=http://localhost:5173

# M-Pesa (Safaricom Daraja)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_ENV=sandbox

# Selcom
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=

# AzamPay
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
AZAMPAY_ENV=sandbox

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
